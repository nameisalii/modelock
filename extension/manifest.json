{
  "manifest_version": 3,
  "name": "ModeLock",
  "version": "1.0.0",
  "description": "Build your own internet rules. Activate custom browsing modes and enforce focus through your browser.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.modelock.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
